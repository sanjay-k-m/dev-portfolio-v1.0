---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";
import "../styles/global.css";

const lastUpdated = "May 23, 2026";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Terms of Service for Sanjay Flow — a developer automation platform offering WhatsApp Cloud API integrations, workflow automation, and messaging services by Sanjay Km." />
    <meta name="keywords" content="Sanjay Flow Terms of Service, WhatsApp Cloud API terms, SaaS legal pages, developer tools terms, workflow automation platform, messaging platform terms, Meta compliance" />
    <link rel="canonical" href="https://www.sanjaykm.com/terms" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.sanjaykm.com/terms" />
    <meta property="og:title" content="Terms of Service — Sanjay Flow | Developer Automation Platform" />
    <meta property="og:description" content="Review the Terms of Service governing use of the Sanjay Flow platform, including WhatsApp Cloud API integrations, workflow automation, and developer tools." />
    <meta property="og:site_name" content="Sanjay Km Portfolio" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://www.sanjaykm.com/terms" />
    <meta property="twitter:title" content="Terms of Service — Sanjay Flow | Developer Automation Platform" />
    <meta property="twitter:description" content="Review the Terms of Service governing use of the Sanjay Flow platform, including WhatsApp Cloud API integrations, workflow automation, and developer tools." />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <title>Terms of Service — Sanjay Flow | Developer Automation Platform</title>
  </head>
  <body class="bg-white text-gray-800 antialiased font-mono">
    <Header />
    
    <main class="max-w-4xl mx-auto px-6 py-24 md:py-32">
      <!-- Title -->
      <div class="border-b border-gray-200 pb-8 mb-10" style={`--accent-color: ${siteConfig.accentColor}`}>
        <div class="inline-flex items-center gap-x-2 bg-blue-50 border border-blue-200/50 px-3 py-1 mb-4 text-blue-800 text-xs font-bold uppercase tracking-wider">
          <span class="h-1.5 w-1.5 bg-blue-600"></span>
          Legal Agreement
        </div>
        <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tight mb-3 uppercase font-display">
          Terms of Service
        </h1>
        <p class="text-xs font-bold text-gray-400">
          LAST UPDATED: {lastUpdated}
        </p>
      </div>

      <!-- Content Sections -->
      <div class="space-y-12 text-sm md:text-base text-gray-600 leading-relaxed">
        <section id="introduction">
          <h2 class="text-lg font-bold text-gray-900 mb-4 border-b border-gray-100 pb-2 uppercase">
            01. Introduction
          </h2>
          <p class="mb-4">
            Welcome to <strong>Sanjay Flow</strong>, a developer automation platform operated by <strong>Sanjay Km</strong> (accessible at <a href="https://www.sanjaykm.com" class="text-blue-600 hover:text-blue-700 font-medium underline underline-offset-4 transition-colors">https://www.sanjaykm.com</a>). Sanjay Flow provides WhatsApp Cloud API integrations, workflow automation, messaging services, AI integrations, and developer tools designed to help businesses and developers build scalable communication workflows.
          </p>
          <p>
            These Terms of Service ("Terms") constitute a legally binding agreement between you ("User", "you") and Sanjay Flow ("we", "us", "our"). By accessing or using the Sanjay Flow platform, website, APIs, or any associated services, you acknowledge that you have read, understood, and agree to be bound by these Terms in their entirety.
          </p>
        </section>

        <section id="acceptance">
          <h2 class="text-lg font-bold text-gray-900 mb-4 border-b border-gray-100 pb-2 uppercase">
            02. Acceptance of Terms
          </h2>
          <p class="mb-4">
            By creating an account, accessing the platform, or using any Sanjay Flow service — including our APIs, webhooks, WhatsApp Flows, or cloud integrations — you agree to comply with and be bound by these Terms. If you are using the platform on behalf of an organization, you represent and warrant that you have the authority to bind that organization to these Terms.
          </p>
          <p>
            If you do not agree to these Terms, you must discontinue use of the platform immediately. Continued use of any Sanjay Flow service constitutes ongoing acceptance of the most current version of these Terms.
          </p>
        </section>

        <section id="use-of-services">
          <h2 class="text-lg font-bold text-gray-900 mb-4 border-b border-gray-100 pb-2 uppercase">
            03. Use of Services
          </h2>
          <p class="mb-4">
            Sanjay Flow offers a suite of developer-oriented services, including but not limited to:
          </p>
          <ul class="list-disc pl-5 space-y-2 mb-4">
            <li><strong>WhatsApp Cloud API Integrations:</strong> Tools for connecting with and automating messaging via the Meta WhatsApp Business Platform.</li>
            <li><strong>WhatsApp Flows:</strong> Interactive form-based workflows delivered through the WhatsApp messaging interface.</li>
            <li><strong>Workflow Automation:</strong> Backend process orchestration, webhook management, and event-driven automation pipelines.</li>
            <li><strong>APIs & Developer Tools:</strong> RESTful APIs, SDKs, and integration utilities for building custom communication solutions.</li>
            <li><strong>AI Integrations:</strong> AI-powered features embedded into messaging and automation workflows.</li>
            <li><strong>Cloud Services:</strong> Hosted infrastructure for running automated messaging and integration services.</li>
          </ul>
          <p>
            You agree to use these services only for lawful purposes and in compliance with all applicable local, national, and international laws and regulations. You are responsible for all activity that occurs under your account.
          </p>
        </section>

        <section id="prohibited-activities">
          <h2 class="text-lg font-bold text-gray-900 mb-4 border-b border-gray-100 pb-2 uppercase">
            04. Prohibited Activities
          </h2>
          <p class="mb-4">
            When using Sanjay Flow services, you agree not to:
          </p>
          <ul class="list-disc pl-5 space-y-2 mb-4">
            <li>Send unsolicited bulk messages, spam, or engage in any form of abusive messaging practices.</li>
            <li>Use the platform to harass, threaten, defame, or harm any individual or entity.</li>
            <li>Attempt to gain unauthorized access to any part of the platform, other user accounts, or connected systems.</li>
            <li>Reverse engineer, decompile, or disassemble any component of the Sanjay Flow platform.</li>
            <li>Use the services to distribute malware, phishing content, or any other malicious material.</li>
            <li>Violate the intellectual property rights of Sanjay Flow, Meta Platforms, or any third party.</li>
            <li>Resell, sublicense, or redistribute access to Sanjay Flow services without prior written consent.</li>
            <li>Circumvent rate limits, security controls, or any technical restrictions implemented by the platform.</li>
          </ul>
          <p class="font-semibold text-gray-900 border-l-2 border-blue-600 pl-3 py-1 bg-gray-50">
            Anti-Spam Policy: Sanjay Flow enforces a strict zero-tolerance policy toward spam and messaging abuse. Accounts found in violation will be suspended immediately and may be reported to Meta and relevant authorities.
          </p>
        </section>

        <section id="meta-compliance">
          <h2 class="text-lg font-bold text-gray-900 mb-4 border-b border-gray-100 pb-2 uppercase">
            05. WhatsApp & Meta Platform Compliance
          </h2>
          <p class="mb-4">
            Sanjay Flow integrates with Meta Platforms, Inc. services, including the WhatsApp Business Platform and WhatsApp Cloud API. As a user of the Sanjay Flow platform, you are required to:
          </p>
          <ul class="list-disc pl-5 space-y-2 mb-4">
            <li>Comply with the <strong>Meta Platform Terms</strong> and <strong>Developer Policies</strong> at all times.</li>
            <li>Adhere to the <strong>WhatsApp Business Messaging Policy</strong>, including obtaining proper opt-in consent before messaging end users.</li>
            <li>Use WhatsApp message templates only as approved by Meta, and refrain from sending prohibited content categories.</li>
            <li>Ensure that your use of the WhatsApp Cloud API through Sanjay Flow complies with Meta's Commerce Policy and data handling requirements.</li>
            <li>Not use the platform in any way that would cause Sanjay Flow or its users to violate Meta's terms of service.</li>
          </ul>
          <p>
            Sanjay Flow reserves the right to suspend or terminate access for any user whose actions violate Meta Platform policies or jeopardize the platform's compliance standing.
          </p>
        </section>

        <section id="intellectual-property">
          <h2 class="text-lg font-bold text-gray-900 mb-4 border-b border-gray-100 pb-2 uppercase">
            06. Intellectual Property
          </h2>
          <p class="mb-4">
            All content, features, and functionality of the Sanjay Flow platform — including but not limited to the website design, source code, APIs, documentation, logos, and brand assets — are the exclusive property of Sanjay Km and are protected under applicable intellectual property laws.
          </p>
          <p class="mb-4">
            You retain ownership of any data, content, or materials you submit to the platform. By using our services, you grant Sanjay Flow a limited, non-exclusive, revocable license to process your data solely for the purpose of delivering the requested services.
          </p>
          <p>
            Unauthorized use, reproduction, or distribution of any Sanjay Flow intellectual property without express written permission is strictly prohibited.
          </p>
        </section>

        <section id="service-availability">
          <h2 class="text-lg font-bold text-gray-900 mb-4 border-b border-gray-100 pb-2 uppercase">
            07. Service Availability
          </h2>
          <p class="mb-4">
            Sanjay Flow strives to maintain high availability across all services. However, we do not guarantee uninterrupted or error-free access to the platform. Services may be temporarily unavailable due to:
          </p>
          <ul class="list-disc pl-5 space-y-2 mb-4">
            <li>Scheduled maintenance, updates, or infrastructure upgrades.</li>
            <li>Unforeseeable technical failures, network outages, or force majeure events.</li>
            <li>Changes to third-party services, including Meta Platform APIs or cloud providers.</li>
          </ul>
          <p class="mb-4">
            We reserve the right to modify, suspend, or discontinue any feature or service at our discretion, with or without prior notice. Where feasible, we will provide reasonable advance notification of significant changes.
          </p>
          <p>
            Sanjay Flow is under active development. Features, APIs, and integrations may evolve over time as the platform grows and adapts to new requirements.
          </p>
        </section>

        <section id="limitation-of-liability">
          <h2 class="text-lg font-bold text-gray-900 mb-4 border-b border-gray-100 pb-2 uppercase">
            08. Limitation of Liability
          </h2>
          <p class="mb-4">
            To the fullest extent permitted by applicable law, Sanjay Flow, its developer, and affiliates shall not be liable for any indirect, incidental, special, consequential, or punitive damages arising from or related to your use of (or inability to use) the platform, including but not limited to:
          </p>
          <ul class="list-disc pl-5 space-y-2 mb-4">
            <li>Loss of data, revenue, profits, or business opportunities.</li>
            <li>Service interruptions or downtime.</li>
            <li>Unauthorized access to or alteration of your transmissions or data.</li>
            <li>Actions or failures of third-party services, including Meta Platforms or cloud infrastructure providers.</li>
          </ul>
          <p>
            The Sanjay Flow platform is provided on an "as is" and "as available" basis. We make no warranties, express or implied, regarding the reliability, accuracy, or fitness of the platform for any particular purpose.
          </p>
        </section>

        <section id="changes-to-terms">
          <h2 class="text-lg font-bold text-gray-900 mb-4 border-b border-gray-100 pb-2 uppercase">
            09. Changes to Terms
          </h2>
          <p class="mb-4">
            Sanjay Flow reserves the right to update or modify these Terms at any time. When changes are made, the "Last Updated" date at the top of this page will be revised accordingly.
          </p>
          <p>
            Continued use of the platform after any modifications constitutes your acceptance of the revised Terms. We encourage you to review this page periodically to stay informed of any updates. For material changes that significantly affect your rights, we will make reasonable efforts to notify active users via email or through the platform interface.
          </p>
        </section>

        <section id="contact-information">
          <h2 class="text-lg font-bold text-gray-900 mb-4 border-b border-gray-100 pb-2 uppercase">
            10. Contact Information
          </h2>
          <p class="mb-4">
            If you have questions about these Terms, need clarification on any section, or wish to report a policy violation, please reach out to us:
          </p>
          <div class="border border-gray-200 bg-gray-50 p-6 grid grid-cols-1 sm:grid-cols-2 gap-6 text-sm">
            <div>
              <p class="text-xs font-bold uppercase tracking-wider text-gray-400">Developer Name</p>
              <p class="text-gray-900 font-semibold mt-1">Sanjay Km</p>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-wider text-gray-400">Contact Email</p>
              <a href="mailto:contact@sanjaykm.com" class="text-blue-600 hover:text-blue-700 font-semibold transition-colors mt-1 block">contact@sanjaykm.com</a>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-wider text-gray-400">Phone</p>
              <a href="tel:+918547863419" class="text-gray-700 hover:text-gray-900 transition-colors mt-1 block font-medium">+91 8547863419</a>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-wider text-gray-400">Website</p>
              <a href="https://www.sanjaykm.com" class="text-blue-600 hover:text-blue-700 font-semibold transition-colors mt-1 block">https://www.sanjaykm.com</a>
            </div>
          </div>
        </section>
      </div>
    </main>

    <Footer />
  </body>
</html>
